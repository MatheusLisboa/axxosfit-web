# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL pública do app (Cloud Run, Vercel, etc.)
APP_URL="http://localhost:3000"

# VITE_API_URL: opcional — use quando o front e a API estiverem em hosts diferentes
# Ex.: front no Cloud Run estático e API na Vercel: VITE_API_URL="https://seu-projeto.vercel.app"
VITE_API_URL=

# SUPABASE_URL: URL do seu projeto do Supabase.
VITE_SUPABASE_URL="https://fwktwtbdbdvvmipfsyfs.supabase.co"

# SUPABASE_ANON_KEY: Chave anônima pública do Supabase.
VITE_SUPABASE_ANON_KEY="eeyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ3a3R3dGJkYmR2dm1pcGZzeWZzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk4MjQ2MTAsImV4cCI6MjA5NTQwMDYxMH0.g1KKpgU1uTWb5UFnWf4ZTXuqyXYlq4kZF0RfT1NaPow"

# SUPABASE_SERVICE_ROLE_KEY: obrigatória no backend para gravar subscriptions (bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ASAAS: Pagamentos e assinaturas recorrentes (upgrade de plano)
ASAAS_API_KEY=
# Sandbox: https://api-sandbox.asaas.com/v3 | Produção: https://api.asaas.com/v3
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# CPF do personal é obrigatório no perfil para upgrade via Asaas

# Suporte WhatsApp (apenas plano Studio) — DDI + DDD + número, ex.: 5511999999999
VITE_SUPPORT_WHATSAPP=

# RESEND: envio de e-mails transacionais
RESEND_API_KEY=
# Remetente — domínio verificado no Resend: mail.axxosfit.com.br
# Sandbox (só para axxosfit@gmail.com): AxxosFit <onboarding@resend.dev>
RESEND_FROM_EMAIL="AxxosFit <noreply@mail.axxosfit.com.br>"

# MERCADO_PAGO: legado (não usado no upgrade — mantido opcional)
VITE_MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=

